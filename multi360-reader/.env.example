# MODELO — o leitor do Multi360. Copie para .env e preencha.
# Em produção, estes valores vão nas "Variables" do serviço na Railway.
# NUNCA preencha este arquivo com valores reais: ele vai para o GitHub.

# Token do Multi360 (vence a cada ~6 meses; veja o README desta pasta para pegar de novo).
MULTI360_TOKEN=

# Só preencha se o Multi360 passar a exigir o cabeçalho Domain (hoje não exige).
MULTI360_DOMAIN=

# Endereço da API do Multi360 (não mude sem motivo).
MULTI360_BASE_URL=https://painel.multi360.com.br/api

# Banco (Supabase) — mesmo projeto das telas.
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Chave SECRETA (service_role). O leitor grava no banco, então precisa dela.
SUPABASE_SERVICE_ROLE_KEY=

# Empresa (tenant) a que os dados pertencem.
EMPRESA_SLUG=aposentar

# De quantos em quantos minutos buscar conversas novas.
POLL_INTERVAL_MIN=15
