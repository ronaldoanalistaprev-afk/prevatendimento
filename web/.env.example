# MODELO — as telas (Next.js). Copie para .env.local e preencha.
# Em produção, estes valores vão nas "Environment Variables" da Vercel.
# NUNCA preencha este arquivo com valores reais: ele vai para o GitHub.

# Endereço do banco (Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Chave PÚBLICA (anon). Pode aparecer no navegador; é protegida pelas regras do banco.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave SECRETA (service_role) — é a chave de baixo na tela API Keys do Supabase.
# Dá acesso total ao banco, ignorando as regras. Só o servidor usa; nunca o navegador.
SUPABASE_SERVICE_ROLE_KEY=

# Senha combinada para o WhatsApp entregar mensagem na nossa rota de ingestão.
# (Só é usada na trilha do WhatsApp próprio, hoje engavetada.)
INGEST_SECRET=

# Endereço do serviço de WhatsApp (trilha engavetada; deixe em branco se não usar).
WHATSAPP_SERVICE_URL=
